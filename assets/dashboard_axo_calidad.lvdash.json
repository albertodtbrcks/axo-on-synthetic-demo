{
  "datasets": [
    {
      "name": "calkpi",
      "displayName": "Calidad KPI",
      "queryLines": [
        "SELECT round(100*avg(case when had_text_issue then 1 else 0 end),1) pct_error, count(*) total, sum(case when had_text_issue then 1 else 0 end) con_error FROM workspace.`on`.orders_silver"
      ]
    },
    {
      "name": "cuar",
      "displayName": "Cuarentena",
      "queryLines": [
        "SELECT count(*) cuarentena FROM workspace.`on`.products_quarantine"
      ]
    },
    {
      "name": "tipos",
      "displayName": "Tipos de error",
      "queryLines": [
        "SELECT text_issue_type, count(*) filas FROM workspace.`on`.orders_silver GROUP BY 1 ORDER BY 2 DESC"
      ]
    },
    {
      "name": "ejemplos",
      "displayName": "Ejemplos corregidos",
      "queryLines": [
        "SELECT text_issue_type AS tipo_error, item_name AS texto_corregido FROM workspace.`on`.orders_silver WHERE text_issue_type<>'limpio' LIMIT 50"
      ]
    },
    {
      "name": "tipos_hora",
      "displayName": "Errores por hora",
      "queryLines": [
        "SELECT date_trunc('HOUR', order_ts) hora, text_issue_type, count(*) filas FROM workspace.`on`.orders_silver WHERE order_ts IS NOT NULL AND text_issue_type<>'limpio' GROUP BY 1,2 ORDER BY 1"
      ]
    }
  ],
