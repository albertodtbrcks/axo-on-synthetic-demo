{
  "datasets": [
    {
      "name": "kpi",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT count(*) ordenes, sum(order_amount) ventas, sum(quantity) unidades, avg(order_amount) ticket FROM workspace.`on`.fact_orders"
      ]
    },
    {
      "name": "hora",
      "displayName": "Ventas por hora",
      "queryLines": [
        "SELECT date_trunc('HOUR', order_timestamp) hora, sum(order_amount) ventas FROM workspace.`on`.fact_orders WHERE order_timestamp IS NOT NULL GROUP BY 1 ORDER BY 1"
      ]
    },
    {
      "name": "tienda",
      "displayName": "Top tiendas",
      "queryLines": [
        "SELECT store_name, sum(order_amount) ventas FROM workspace.`on`.fact_orders WHERE store_name IS NOT NULL GROUP BY 1 ORDER BY 2 DESC LIMIT 12"
      ]
    },
    {
      "name": "cat",
      "displayName": "Categorias",
      "queryLines": [
        "SELECT split(item_category,' > ')[0] AS categoria, sum(order_amount) ventas FROM workspace.`on`.fact_orders WHERE item_category IS NOT NULL AND item_category<>'' GROUP BY 1 ORDER BY 2 DESC LIMIT 10"
      ]
    },
    {
      "name": "canal",
      "displayName": "Canal",
      "queryLines": [
        "SELECT sales_channel canal, count(*) ordenes FROM workspace.`on`.fact_orders GROUP BY 1"
      ]
    },
    {
      "name": "pago",
      "displayName": "Pago",
      "queryLines": [
        "SELECT payment_method metodo, count(*) ordenes FROM workspace.`on`.fact_orders WHERE payment_method IS NOT NULL GROUP BY 1 ORDER BY 2 DESC"
      ]
    }
  ],
